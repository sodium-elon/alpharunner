{
  "name": "alpharunner",
  "version": "0.1.0",
  "private": true,
  "description": "AlphaRunner MVP - dashboard and control center for tracking runs",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "predev": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "dev": "dotenv -e ../env-profiles/local.env -- vite dev --strictPort",
    "dev:msw": "dotenv -e ../env-profiles/local.env -- sh -c 'MSW=true vite dev --strictPort'",
    "dev:prod": "dotenv -e ../env-profiles/prod.env -- vite dev --strictPort",
    "build": "pnpm build:local",
    "build:local": "dotenv -e ../env-profiles/local.env -- vite build",
    "build:prod": "dotenv -e ../env-profiles/prod.env -- vite build",
    "build:msw": "dotenv -e ../env-profiles/prod.env -- sh -c 'MSW=true vite build'",
    "preview": "dotenv -e ../env-profiles/local.env -- vite preview",
    "preview:prod": "dotenv -e ../env-profiles/prod.env -- vite preview",
    "start": "dotenv -e ../env-profiles/local.env -- node .output/server/index.mjs",
    "start:prod": "dotenv -e ../env-profiles/prod.env -- node .output/server/index.mjs",
    "start:msw": "dotenv -e ../env-profiles/prod.env -- sh -c 'MSW=true node .output/server/index.mjs'",
    "db:generate": "dotenv -e ../env-profiles/local.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../env-profiles/local.env -- drizzle-kit migrate",
    "db:migrate:prod": "dotenv -e ../env-profiles/prod.env -- drizzle-kit migrate",
    "db:push": "dotenv -e ../env-profiles/local.env -- drizzle-kit push",
    "db:push:prod": "dotenv -e ../env-profiles/prod.env -- drizzle-kit push",
    "db:studio": "dotenv -e ../env-profiles/local.env -- drizzle-kit studio",
    "db:studio:prod": "dotenv -e ../env-profiles/prod.env -- drizzle-kit studio",
    "db:import-seed": "dotenv -e ../env-profiles/local.env -- tsx src/db/import-seed.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "^1.144.0",
    "@tanstack/react-router-devtools": "^1.144.0",
    "@tanstack/react-router-ssr-query": "^1.144.0",
    "@tanstack/react-start": "^1.145.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js-light": "^2.5.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.562.0",
    "nitro": "3.0.1-alpha.1",
    "postgres": "^3.4.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.8.0",
    "shadcn": "^4.6.0",
    "simple-icons": "^16.18.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "msw": "^2.14.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}